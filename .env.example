# =============================================================================
# Video Auto-Poster — environment secrets
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Every value here is a SECRET. config.yaml holds the non-secret settings.
# See CREDENTIALS.md for exact step-by-step instructions to obtain each one.
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic — the ONLY LLM call (metadata generation)
# -----------------------------------------------------------------------------
# Get from https://console.anthropic.com/ → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Dropbox — scoped app with a long-lived refresh token
# Scopes required: files.content.read, files.content.write, files.metadata.read
# -----------------------------------------------------------------------------
DROPBOX_APP_KEY=xxxxxxxxxxxxxxx
DROPBOX_APP_SECRET=xxxxxxxxxxxxxxx
# Long-lived refresh token (NOT a short-lived access token). See CREDENTIALS.md.
DROPBOX_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# YouTube (Google Cloud OAuth — Desktop client)
# API: YouTube Data API v3   Scope: https://www.googleapis.com/auth/youtube.upload
# CRITICAL: the OAuth consent screen MUST be published to "In production",
# otherwise the refresh token silently expires after 7 days. See CREDENTIALS.md.
# -----------------------------------------------------------------------------
YOUTUBE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Minted once by running:  python youtube_auth.py   (built in a later step)
YOUTUBE_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Facebook posting was REMOVED (it was suppressing the FB algorithm). This poster
# is YouTube-only now, so no FACEBOOK_* secrets are required.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# MERCH auto-poster (Dropbox -> Printify -> Etsy draft). See merch/README.md.
# -----------------------------------------------------------------------------
# Printify token: printify.com -> Account -> Connections (API) -> Generate.
PRINTIFY_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The Etsy-connected Printify shop id. Get it: python merch/discover_blanks.py stores
PRINTIFY_SHOP_ID=xxxxxxxx
# Free phone-push topic (ntfy.sh). Subscribe to this exact string in the ntfy app.
NTFY_TOPIC=crv-merch-xxxxxxxxxx
